<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="relateai.db"/>
        <exclude domain="database" path="relateai.db-wal"/>
        <exclude domain="database" path="relateai.db-shm"/>
        <exclude domain="sharedpref" path="relateai_auth_prefs.xml"/>
        <exclude domain="sharedpref" path="relateai_config_prefs.xml"/>
        <exclude domain="sharedpref" path="relateai_db_meta_secure.xml"/>
        <exclude domain="sharedpref" path="relateai_db_meta.xml"/>
        <exclude domain="sharedpref" path="encrypted_prefs.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="relateai.db"/>
        <exclude domain="database" path="relateai.db-wal"/>
        <exclude domain="database" path="relateai.db-shm"/>
        <exclude domain="sharedpref" path="relateai_auth_prefs.xml"/>
        <exclude domain="sharedpref" path="relateai_config_prefs.xml"/>
        <exclude domain="sharedpref" path="relateai_db_meta_secure.xml"/>
        <exclude domain="sharedpref" path="relateai_db_meta.xml"/>
        <exclude domain="sharedpref" path="encrypted_prefs.xml"/>
    </device-transfer>
</data-extraction-rules>
